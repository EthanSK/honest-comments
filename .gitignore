node_modules/
__pycache__/
*.pyc
.env
# Ignore the WHOLE out/ dir — it holds the creator's fetched comments plus every
# intermediate file the analyzer writes (run_meta.json, classified_*.json,
# claims.json, themes.json). The old `comments_*.json` pattern only caught the
# raw dump and would have let run_meta / classified / claims / themes get
# committed by accident. /out/ is the creator's local data — never commit it.
/out/
comments_*.json

# OAuth / credential files. The real ones live in ~/.honest-comments/ (the
# user's HOME, NOT the repo), so they're already out of the repo's reach — but
# guard DEFENSIVELY in case someone runs the scripts from inside the repo or
# drops a client config / token here by hand. NEVER commit a creator's OAuth
# tokens (youtube_token.json) or the owner's downloaded Google OAuth client
# JSON (client_config.json).
.honest-comments/
client_config.json
youtube_token.json

.DS_Store
